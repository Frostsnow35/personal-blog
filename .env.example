# Vercel + Supabase production variables.
# Add these in Vercel Project Settings -> Environment Variables.

FLASK_ENV=production
FLASK_DEBUG=false

# Supabase: use the Transaction pooler URI for Vercel serverless.
# Example shape:
# postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Generate strong random values before production deployment.
SECRET_KEY=replace-with-a-random-secret
JWT_SECRET=replace-with-a-random-jwt-secret

# The first deployment can use ADMIN_PASSWORD. Remove it or switch to
# ADMIN_PASSWORD_HASH after the initial admin account is created.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
# ADMIN_PASSWORD_HASH=

# Set these after Vercel gives you a production URL or custom domain.
SITE_URL=https://your-project.vercel.app
CORS_ORIGINS=https://your-project.vercel.app,https://your-domain.com

# Keep blank when frontend and API are deployed in the same Vercel project.
VITE_API_BASE_URL=
VITE_APP_TITLE=Personal Blog
VITE_APP_DESCRIPTION=My personal blog
VITE_APP_DOMAIN=your-project.vercel.app
