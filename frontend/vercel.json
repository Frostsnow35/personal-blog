{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:prod",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "functions": {
    "api/[...path].py": {
      "runtime": "@vercel/python@4.2.0",
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...path]"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/$1"
    },
    {
      "source": "/",
      "destination": "/dist/index.html"
    }
  ]
}