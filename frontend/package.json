{
  "name": "personal-blog-frontend",
  "version": "1.0.0",
  "description": "个人博客前端项目",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "vite build",
    "build:typecheck": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "vercel-build": "npm run build:prod",
    "netlify-build": "npm install --legacy-peer-deps && npm run build"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/core": "^3.27.3",
    "@tiptap/extension-image": "^3.27.3",
    "@tiptap/extension-link": "^3.27.3",
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/extension-text-style": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "@tiptap/vue-3": "^3.27.3",
    "dompurify": "^3.4.2",
    "gsap": "^3.12.2",
    "markdown-it": "^14.1.1",
    "pinia": "^2.1.6",
    "three": "^0.155.0",
    "tiptap-markdown": "^0.9.0",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4",
    "vue3-toastify": "^0.2.9"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.10.4",
    "@types/markdown-it": "^14.1.2",
    "@types/three": "^0.155.0",
    "@vitejs/plugin-vue": "^4.3.4",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/tsconfig": "^0.4.0",
    "autoprefixer": "^10.4.15",
    "esbuild": "^0.19.0",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "postcss": "^8.4.29",
    "prettier": "^3.0.3",
    "tailwindcss": "^3.3.3",
    "terser": "^5.43.1",
    "typescript": "~5.2.0",
    "vite": "^4.4.9",
    "vue-tsc": "^1.8.15"
  }
}
