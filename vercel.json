{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm install && npm run build:prod",
  "devCommand": "cd frontend && npm run dev",
  "installCommand": "npm install && pip install -r requirements.txt",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/index"
    },
    {
      "source": "/:path*",
      "destination": "/frontend/dist/:path*"
    },
    {
      "source": "/",
      "destination": "/frontend/dist/index.html"
    }
  ]
}