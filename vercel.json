{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pip install --break-system-packages -r requirements.txt && cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build:prod",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/music-favorites", "destination": "/api/index.py" },
    { "source": "/music-favorites/:path*", "destination": "/api/index.py" },
    { "source": "/movie-favorites/:path*", "destination": "/api/index.py" },
    { "source": "/friend-links/:path*", "destination": "/api/index.py" },
    { "source": "/albums/:path*", "destination": "/api/index.py" },
    { "source": "/uploads/:path*", "destination": "/api/index.py" },
    { "source": "/((?!api/|assets/|js/|.*\\..*).*)", "destination": "/index.html" }
  ]
}
