{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm install && npm run build",
  "devCommand": "cd frontend && npm run dev",
  "installCommand": "pip install -r backend/requirements.txt",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/dist/js/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/dist/assets/$1"
    },
    {
      "src": "/audio/(.*)",
      "dest": "/frontend/dist/audio/$1"
    },
    {
      "src": "/sw\\.js",
      "dest": "/frontend/dist/sw.js"
    },
    {
      "src": "/favicon\\.svg",
      "dest": "/frontend/dist/favicon.svg"
    },
    {
      "src": "/manifest\\.webmanifest",
      "dest": "/frontend/dist/manifest.webmanifest"
    },
    {
      "src": "/robots\\.txt",
      "dest": "/frontend/dist/robots.txt"
    },
    {
      "src": "/avatar\\.jpg",
      "dest": "/frontend/dist/avatar.jpg"
    },
    {
      "src": "/profile\\.jpg",
      "dest": "/frontend/dist/profile.jpg"
    },
    {
      "src": "^/uptime$",
      "dest": "/uptime.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}