{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pip install --break-system-packages -r requirements.txt && cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build:prod",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/music.js": {
      "runtime": "@vercel/node@3.2.0"
    }
  },
  "rewrites": [
    { "source": "/api/music", "destination": "/api/music.js" },
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/music-favorites/:path*", "destination": "/api/index" },
    { "source": "/movie-favorites/:path*", "destination": "/api/index" },
    { "source": "/friend-links/:path*", "destination": "/api/index" },
    { "source": "/albums/:path*", "destination": "/api/index" },
    { "source": "/uploads/:path*", "destination": "/api/index" },
    { "source": "/((?!api/|assets/|js/|.*\\..*).*)", "destination": "/index.html" }
  ]
}
