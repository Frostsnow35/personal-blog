# Backend environment variables for local development or Vercel.

# Local default can be omitted to use backend/personal_blog.db.
# For Supabase on Vercel, use the Transaction pooler connection string:
# postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

SECRET_KEY=replace-with-a-random-secret
JWT_SECRET=replace-with-a-random-jwt-secret

FLASK_ENV=development
FLASK_DEBUG=true
SITE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,https://*.vercel.app

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# ADMIN_PASSWORD_HASH=
